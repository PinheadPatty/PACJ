<?xml version="1.0"?>
<robot name="rover" xmlns:xacro="http://www.ros.org">

  <!-- Base Link (Invisible center of the robot) -->
  <link name="base_link"/>
  <link name="left_wheel"/>
  <link name="right_wheel"/>

  <!-- 2. DEFINE PHYSICAL JOINTS (This is what's missing!) -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ros2_control description -->
  <ros2_control name="RoverHardware" type="system">
    <hardware>
      <plugin>dynamixel_hardware_interface/DynamixelHardwareInterface</plugin>
      <param name="usb_port">/dev/ttyUSB0</param>
      <param name="baud_rate">57600</param>
    </hardware>
    <joint name="left_wheel_joint">
      <param name="id">2</param>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <param name="id">1</param>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
</robot>
